#!/bin/sh
# SpecGate optional pre-commit hook sample.
# Install manually only if needed:
#   cp hooks/pre-commit.sample .git/hooks/pre-commit
#
# This hook is not part of the SpecGate runtime. It demonstrates Lab 11 / HE
# guardrails: secret scanning, required task files, and verification reminders.

set -eu

echo "[SpecGate hook] checking staged files"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM || true)
SECRET_PATTERNS='(OPENAI_API_KEY|GEMINI_API_KEY|ANTHROPIC_API_KEY|sk-[A-Za-z0-9_-]{20,}|AIza[0-9A-Za-z_-]{20,}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----)'

if [ -n "$STAGED_FILES" ]; then
  if git grep --cached -n -E "$SECRET_PATTERNS" -- $STAGED_FILES >/tmp/specgate-secret-scan.txt 2>/dev/null; then
    echo "[SpecGate hook] suspected secret found in staged files:"
    cat /tmp/specgate-secret-scan.txt
    echo "[SpecGate hook] remove the secret before committing."
    exit 1
  fi
fi

for required in \
  "examples/knowledge_nav/TASK_SPEC.md" \
  "examples/knowledge_nav/CHECKLIST.md" \
  "examples/knowledge_nav/specgate.toml"
do
  if [ ! -f "$required" ]; then
    echo "[SpecGate hook] missing required demo task file: $required"
    exit 1
  fi
done

echo "[SpecGate hook] no suspicious secrets found."
echo "[SpecGate hook] required demo task files exist."
echo "[SpecGate hook] recommended verification before push:"
echo "  PYTHONPATH=src python -m unittest discover -s tests -v"

exit 0
